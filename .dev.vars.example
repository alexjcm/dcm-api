APP_ENV=development
AUTH0_ISSUER=https://dcm-platform.us.auth0.com/
AUTH0_AUDIENCE=https://api.dcm

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

TZ_BUSINESS=America/Guayaquil
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_BUCKETS=5000

SESSION_TOKEN_SECRET=...


# Auth0 - Integración Machine to Machine (M2M). Permite a la API Hono gestionar usuarios en Auth0
AUTH0_DOMAIN=dcm-platform.us.auth0.com
AUTH0_M2M_CLIENT_ID=...
AUTH0_M2M_CLIENT_SECRET=...
AUTH0_CONNECTION=Username-Password-Authentication
AUTH0_M2M_AUDIENCE=https://dcm-platform.us.auth0.com/api/v2/
AUTH0_VIEWER_ROLE_ID=...
