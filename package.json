{
  "name": "contributions-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "wrangler dev src/index.ts",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:migrate:local": "wrangler d1 migrations apply CONTRIBUTIONS_DB_BINDING --local",
    "db:migrate:remote": "wrangler d1 migrations apply CONTRIBUTIONS_DB_BINDING --remote",
    "db:create": "wrangler d1 create contributions-db-development --binding CONTRIBUTIONS_DB_BINDING --update-config",
    "phase2:build-sql": "node scripts/phase2/build-historical-sql.mjs",
    "phase2:load:local": "wrangler d1 execute CONTRIBUTIONS_DB_BINDING --local --file data/historical/sql/phase2-historical-import.sql",
    "phase2:load:remote": "wrangler d1 execute CONTRIBUTIONS_DB_BINDING --remote --file data/historical/sql/phase2-historical-import.sql"
  },
  "dependencies": {
    "@hono/clerk-auth": "^3.1.1",
    "@hono/zod-validator": "^0.7.0",
    "drizzle-orm": "^0.44.2",
    "hono": "^4.10.1",
    "xlsx": "^0.18.5",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260405.0",
    "drizzle-kit": "^0.31.4",
    "typescript": "^5.9.3",
    "wrangler": "^4.11.1"
  }
}
