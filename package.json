{
  "name": "contributions-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "wrangler --config wrangler.dev.jsonc dev src/index.ts --local",
    "deploy": "wrangler deploy",
    "deploy:prod": "wrangler deploy",
    "preview": "wrangler versions upload",
    "typecheck": "tsc --noEmit",
    "types:wrangler": "wrangler --config wrangler.dev.jsonc types",
    "d1:generate": "drizzle-kit generate --config drizzle.config.ts",
    "d1:check": "drizzle-kit check --config drizzle.config.ts",
    "d1:migrate:local": "wrangler --config wrangler.dev.jsonc d1 migrations apply CONTRIBUTIONS_DB_BINDING --local",
    "d1:migrate:prod": "wrangler d1 migrations apply CONTRIBUTIONS_DB_BINDING --remote",
    "d1:reset:local": "./tools/d1-reset-local.sh",
    "d1:seed:local": "./tools/d1-seed-local.sh",
    "d1:bootstrap:local": "npm run d1:reset:local && npm run d1:seed:local",
    "d1:snapshot:local": "./tools/d1-snapshot-local.sh",
    "d1:restore:local": "./tools/d1-restore-local.sh",
    "tool:d1:inspect:prod": "./tools/d1-inspect.sh --remote",
    "tool:smoke:rbac:prod": "./tools/smoke-rbac-production.sh"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.12",
    "jose": "^6.2.2",
    "xlsx": "^0.18.5",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.6.2",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.9.3",
    "wrangler": "^4.82.2"
  }
}
